# Public keys only — safe to embed in the frontend build
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# Admin login is NOT stored here.
# Create ONE user in Supabase Dashboard → Authentication → Users.
# Disable public sign-ups: Authentication → Providers → Email → turn off sign-ups.
# Run supabase/secure-setup.sql and set YOUR_ADMIN_EMAIL to that user's email.
